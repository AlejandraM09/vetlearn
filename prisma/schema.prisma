// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String?   @unique
  name          String
  password      String
  role          Role      @default(STUDENT)
  avatar        String?
  xp            Int       @default(0)
  level         Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  progress      ModuleProgress[]
  quizAttempts  QuizAttempt[]
  favorites     FavoriteSpecies[]
  badges        UserBadge[]
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Module {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  icon        String
  color       String
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards     ModuleCard[]
  progress  ModuleProgress[]
  quizzes   Quiz[]

  @@map("modules")
}

model ModuleCard {
  id          String   @id @default(cuid())
  moduleId    String
  title       String
  content     String   @db.Text
  imageUrl    String?
  tips        String[]
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("module_cards")
}

model ModuleProgress {
  id          String   @id @default(cuid())
  userId      String
  moduleId    String
  completed   Boolean  @default(false)
  percentage  Int      @default(0)
  startedAt   DateTime @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@map("module_progress")
}

model Species {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  latinName   String
  emoji       String
  imageUrl    String?
  createdAt   DateTime          @default(now())

  parameters  SpeciesParameter[]
  favorites   FavoriteSpecies[]

  @@map("species")
}

model SpeciesParameter {
  id        String  @id @default(cuid())
  speciesId String
  label     String
  value     String
  unit      String
  rangeMin  Float
  rangeMax  Float
  order     Int     @default(0)

  species   Species @relation(fields: [speciesId], references: [id], onDelete: Cascade)

  @@map("species_parameters")
}

model FavoriteSpecies {
  id        String   @id @default(cuid())
  userId    String
  speciesId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  species Species @relation(fields: [speciesId], references: [id], onDelete: Cascade)

  @@unique([userId, speciesId])
  @@map("favorite_species")
}

model Quiz {
  id          String   @id @default(cuid())
  moduleId    String?
  title       String
  description String?
  createdAt   DateTime @default(now())

  module    Module?      @relation(fields: [moduleId], references: [id])
  questions Question[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model Question {
  id            String   @id @default(cuid())
  quizId        String
  text          String   @db.Text
  options       String[]
  correctIndex  Int
  explanation   String   @db.Text
  order         Int      @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  score     Int
  total     Int
  xpEarned  Int      @default(0)
  answers   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

model Badge {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  icon        String
  condition   String
  xpReward    Int         @default(0)

  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

enum Role {
  STUDENT
  ADMIN
}
