# ─────────────────────────────────────────────
#  VetLearn — Environment Variables
# ─────────────────────────────────────────────

# PostgreSQL connection string (Vercel Postgres or Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/vetlearn?sslmode=require"

# NextAuth / Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Optional: AI assistant integration
ANTHROPIC_API_KEY="sk-ant-..."

# Vercel Postgres (auto-set when linking project in Vercel)
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=
